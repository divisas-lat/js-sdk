{
  "name": "@divisas-lat/js-sdk",
  "version": "1.0.0",
  "description": "El SDK oficial de Node.js/TypeScript para Divisas.lat",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "divisas": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "divisas",
    "tipo de cambio",
    "guatemala",
    "sdk"
  ],
  "author": "Divisas Latinoamerica",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
